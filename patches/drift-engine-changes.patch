diff --git a/browser/app/profile/firefox.js b/browser/app/profile/firefox.js
index 2b852e0225..903461ddd7 100644
--- a/browser/app/profile/firefox.js
+++ b/browser/app/profile/firefox.js
@@ -3623,3 +3623,57 @@ pref("browser.contentsharing.enabled", false);
 
 // When enabled, Firefox ignores the distribution.ini file if global.id is MozillaOnline.
 pref("distribution.mozillaonline.ignore", true);
+
+// Drift: start with a blank page instead of the Firefox default home
+pref("browser.startup.page", 1);
+pref("browser.startup.homepage", "about:newtab");
+
+// Drift: minimal chrome defaults — bookmarks bar hidden, sidebar closed
+pref("browser.toolbars.bookmarks.visibility", "never");
+pref("sidebar.visibility", "hide-sidebar");
+
+// Drift: disable the Firefox View first-run and tab-tray intro
+pref("browser.firefox-view.feature-tour", "{\"screen\":\"\",\"complete\":true}");
+
+// Drift: suppress the what's new notification badge on first run
+pref("browser.messaging-system.whatsNewPanel.enabled", false);
+
+// Drift: disable activity-stream sponsored content and telemetry
+pref("browser.newtabpage.activity-stream.showSponsored", false);
+pref("browser.newtabpage.activity-stream.showSponsoredTopSites", false);
+pref("browser.newtabpage.activity-stream.feeds.telemetry", false);
+pref("browser.newtabpage.activity-stream.telemetry", false);
+pref("browser.newtabpage.activity-stream.feeds.snippets", false);
+
+// Drift theme engine (read by drift-theme-chrome.js, applied to the chrome root).
+// theme: light | sepia | arctic | dark | midnight | slate | noir
+pref("drift.theme", "light");
+// accent: one of the 14 presets (terracotta sage ocean plum rose amber forest
+// indigo crimson teal cocoa graphite sky fuchsia)
+pref("drift.accent", "terracotta");
+// accentMode: preset | custom
+pref("drift.accentMode", "preset");
+// accentCustom: a hex colour used when accentMode == custom
+pref("drift.accentCustom", "");
+// glass: chrome translucency 20..95 (percent of surface over transparent)
+pref("drift.glass", 45);
+// blur: frost backdrop-filter radius in px (0 disables frost)
+pref("drift.blur", 20);
+// mode: normal | lite | minimal
+pref("drift.mode", "normal");
+// titlebarH: tab/title bar height override in px (0 = theme default)
+pref("drift.titlebarH", 0);
+// Layout flags
+pref("drift.vtabs", false);
+pref("drift.compact", false);
+pref("drift.centerUrl", false);
+pref("drift.acrylic", false);
+
+// Drift: enable the modern (revamped) sidebar on the release channel so vertical
+// tabs are available. The sidebar stays hidden by default (sidebar.visibility);
+// drift.vtabs mirrors into sidebar.verticalTabs via drift-theme-chrome.js.
+pref("sidebar.revamp", true);
+
+// Drift: bundle uBlock Origin. The AMO-signed xpi ships under
+// distribution/extensions and is auto-installed per profile on first run.
+// Signature verification is intentionally left ENABLED (the xpi is signed).
