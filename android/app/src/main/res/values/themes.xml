<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DriftBrowser" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_deep</item>
        <item name="colorOnPrimary">@color/surface_solid</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSurface">@color/surface_solid</item>
        <item name="android:colorBackground">@color/bg1</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/nav_bar</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:fontFamily">sans-serif</item>
        <!-- Disable default ripple on ImageButtons -->
        <item name="imageButtonStyle">@style/Widget.Drift.ImageButton</item>
    </style>

    <style name="Widget.Drift.ImageButton" parent="Widget.AppCompat.ImageButton">
        <item name="android:background">@drawable/icon_btn_bg</item>
    </style>
</resources>
