<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg1">

    <!-- ══ Top toolbar ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/surface_solid"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="6dp"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Lock / search icon -->
        <ImageView
            android:id="@+id/urlSecure"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="4dp"
            android:src="@drawable/ic_lock"
            android:tint="@color/accent"
            android:contentDescription="@string/secure"
            android:visibility="gone" />

        <!-- URL display pill (tappable) -->
        <TextView
            android:id="@+id/urlBar"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/search_hint"
            android:textColor="@color/text2"
            android:textSize="14sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:background="@drawable/urlbar_bg"
            android:clickable="true"
            android:focusable="true" />

        <!-- New tab button -->
        <ImageButton
            android:id="@+id/btnNewTabTop"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_add_tab"
            android:tint="@color/text2"
            android:background="@drawable/icon_btn_bg"
            android:contentDescription="@string/new_tab"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ══ Progress bar ═════════════════════════════════════════════════════ -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:max="100"
        android:progressTint="@color/accent"
        android:progressBackgroundTint="@color/border"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══ GeckoView (browser content) ══════════════════════════════════════ -->
    <org.mozilla.geckoview.GeckoView
        android:id="@+id/geckoView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/progressBar"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══ Bottom navigation bar ════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/surface_solid"
        android:elevation="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/ic_back"
            android:tint="@color/text2"
            android:background="@drawable/icon_btn_bg"
            android:enabled="false"
            android:contentDescription="@string/back" />

        <ImageButton
            android:id="@+id/btnForward"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/ic_forward"
            android:tint="@color/text2"
            android:background="@drawable/icon_btn_bg"
            android:enabled="false"
            android:contentDescription="@string/forward" />

        <ImageButton
            android:id="@+id/btnReload"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/ic_reload"
            android:tint="@color/text2"
            android:background="@drawable/icon_btn_bg"
            android:contentDescription="@string/reload" />

        <!-- Tab count button (square with number) -->
        <Button
            android:id="@+id/btnTabCount"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="1"
            android:textSize="13sp"
            android:textColor="@color/text1"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/tab_count_btn_bg"
            android:contentDescription="@string/tabs" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/ic_menu"
            android:tint="@color/text2"
            android:background="@drawable/icon_btn_bg"
            android:contentDescription="@string/menu" />

    </LinearLayout>

    <!-- ══ URL edit overlay ═════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/urlEditOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/surface_solid"
        android:visibility="gone"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/urlEditRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:layout_gravity="top"
            android:background="@color/surface_solid">

            <ImageButton
                android:id="@+id/btnEditClose"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical"
                android:src="@drawable/ic_back"
                android:tint="@color/text2"
                android:background="@drawable/icon_btn_bg"
                android:contentDescription="@string/back" />

            <EditText
                android:id="@+id/urlEditInput"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:hint="@string/search_hint"
                android:inputType="textUri"
                android:imeOptions="actionGo"
                android:singleLine="true"
                android:background="@drawable/urlbar_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/text1"
                android:textColorHint="@color/text3"
                android:textSize="15sp" />

            <ImageButton
                android:id="@+id/btnEditClear"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical"
                android:src="@drawable/ic_close"
                android:tint="@color/text3"
                android:background="@drawable/icon_btn_bg"
                android:contentDescription="@string/clear" />
        </LinearLayout>

    </FrameLayout>

    <!-- ══ Tab switcher overlay ══════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/tabSwitcherOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/bg1"
        android:visibility="gone"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Tab switcher header -->
            <LinearLayout
                android:id="@+id/tabSwitcherHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/tabs"
                    android:textSize="20sp"
                    android:textColor="@color/text1"
                    android:fontFamily="sans-serif-medium" />

                <ImageButton
                    android:id="@+id/btnTabSwitcherNew"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_add_tab"
                    android:tint="@color/accent"
                    android:background="@drawable/icon_btn_bg"
                    android:contentDescription="@string/new_tab" />

                <ImageButton
                    android:id="@+id/btnTabSwitcherClose"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_close"
                    android:tint="@color/text2"
                    android:background="@drawable/icon_btn_bg"
                    android:contentDescription="@string/close" />
            </LinearLayout>

            <!-- Tab grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/tabRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="8dp"
                android:clipToPadding="false" />
        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
